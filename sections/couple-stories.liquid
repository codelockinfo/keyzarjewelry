<div class="couple-stories-section color-{{ section.settings.color_scheme }}">
  <couple-stories-slider class="cs-slider-container" data-section-id="{{ section.id }}" data-autoplay="{{ section.settings.autoplay }}">
    
    {%- if section.settings.title != blank -%}
      <div class="cs-section-header">
        <h2 class="cs-section-title">{{ section.settings.title }}</h2>
        <div class="cs-slider-arrows {% if section.settings.hide_arrows_mobile %}hide-on-mobile{% endif %}">
          <button class="cs-arrow cs-arrow-prev" aria-label="Previous">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M15 18l-6-6 6-6"/></svg>
          </button>
          <button class="cs-arrow cs-arrow-next" aria-label="Next">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg>
          </button>
        </div>
      </div>
    {%- endif -%}

    <div class="cs-slider-wrapper">
      <div class="cs-slider">
        {%- if section.settings.auto_load -%}
          {%- assign source_stories = shop.metaobjects.couple_story.values -%}
        {%- else -%}
          {%- assign source_stories = section.blocks -%}
        {%- endif -%}

        {%- assign current_index = 0 -%}
        {%- for item in source_stories -%}
          {%- if section.settings.auto_load -%}
            {%- assign story = item -%}
          {%- else -%}
            {%- assign story = item.settings.metaobject.value -%}
          {%- endif -%}
          
          {%- if story != blank -%}
            {%- render 'couple-story-card' with story: story, current_index: current_index -%}
            {%- assign current_index = current_index | plus: 1 -%}
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>

    <!-- Progress Bar -->
    <div class="cs-progress-container">
      <div class="cs-progress-bar"></div>
    </div>

    <!-- Modal Markup -->
    <div class="cs-modal" aria-hidden="true">
      <div class="cs-modal-backdrop"></div>
      <div class="cs-modal-dialog">
        <div class="cs-modal-header-nav">
          <button class="cs-modal-close-new" aria-label="Close">
             <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2"><path d="M18 6L6 18M6 6l12 12"/></svg>
          </button>
          <div class="cs-modal-header-title"></div>
          <button class="cs-modal-next-top" aria-label="Next Story">
            Next <span class="cs-next-label-full"> Story</span> <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2"><path d="M9 18l6-6-6-6"/></svg>
          </button>
        </div>
        <div class="cs-modal-body"></div>
      </div>
    </div>
  </couple-stories-slider>
</div>

{% style %}
  #shopify-section-{{ section.id }} .couple-stories-section {
    padding: {{ section.settings.desktop_padding }};
    --slide-count-desktop: {{ section.settings.slides_desktop }};
    --slide-count-tablet: {{ section.settings.slides_tablet }};
    --slide-count-mobile: {{ section.settings.slides_mobile }};
    --cs-border-radius: {{ section.settings.border_radius }}px;
  }

  @media screen and (max-width: 768px) {
    #shopify-section-{{ section.id }} .couple-stories-section {
      padding: {{ section.settings.mobile_padding }};
    }
  }

  .couple-stories-section {
    overflow: hidden;
  }
  .cs-section-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 30px;
    padding: 0 0;
    max-width: 1400px;
    margin-left: auto;
    margin-right: auto;
    border-bottom: 1px solid rgba(255, 255, 255, 0.2);
    padding-bottom: 15px;
  }
  .cs-section-title {
    font-family: var(--font-heading-family), serif;
    font-size: 2.2rem;
    margin: 0;
    color: inherit;
    font-weight: 400;
    text-transform: uppercase;
  }
  .cs-slider-arrows {
    display: flex;
    gap: 15px;
  }
  .cs-arrow {
    background: transparent;
    border: none;
    color: inherit;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: opacity 0.3s;
    padding: 0;
  }
  .cs-arrow:hover {
    opacity: 0.7;
  }
  .cs-slider-container {
    max-width: 1400px;
    margin: 0 auto;
    position: relative;
    display: block;
  }
  .cs-slider-wrapper {
    position: relative;
  }
  .cs-slider {
    display: flex;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    gap: 20px;
    scrollbar-width: none;
    scroll-behavior: smooth;
    cursor: grab;
    user-select: none;
  }
  .cs-slider:active {
    cursor: grabbing;
  }
  .cs-slider.is-dragging {
    scroll-snap-type: none;
    scroll-behavior: auto;
  }
  .cs-slider::-webkit-scrollbar {
    display: none;
  }
  .cs-slide {
    flex: 0 0 calc((100% - ((var(--slide-count-mobile) - 1) * 20px)) / var(--slide-count-mobile));
    scroll-snap-align: start;
    pointer-events: none; /* Let parent handle dragging */
  }
  .cs-slide > * {
    pointer-events: auto; /* Re-enable for content */
  }
  @media (min-width: 768px) {
    .cs-slide { 
      flex: 0 0 calc((100% - ((var(--slide-count-tablet) - 1) * 20px)) / var(--slide-count-tablet)); 
    }
  }
  @media (min-width: 1024px) {
    .cs-slide { 
      flex: 0 0 calc((100% - ((var(--slide-count-desktop) - 1) * 20px)) / var(--slide-count-desktop)); 
    }
  }

  /* Progress bar */
  .cs-progress-container {
    width: 100%;
    height: 1px;
    background: rgba(255,255,255,0.1);
    margin-top: 40px;
    position: relative;
    max-width: 1400px;
    margin-left: auto;
    margin-right: auto;
  }
  .cs-progress-bar {
    position: absolute;
    top: 0; left: 0;
    height: 100%;
    background: #fff;
    width: 0%;
    transition: width 0.1s linear;
  }

  /* Hide arrows on mobile toggle */
  @media screen and (max-width: 768px) {
    .hide-on-mobile {
      display: none !important;
    }
  }

  /* Card Styles */
  .cs-card {
    position: relative;
    height: 380px;
    border-radius: var(--cs-border-radius);
    overflow: hidden;
    cursor: pointer;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
  }
  @media screen and (min-width: 768px) {
    .cs-card { height: 450px; }
  }

  .cs-card-bg {
    position: absolute;
    top: 0; left: 0; width: 100%; height: 100%;
    z-index: 1;
  }
  .cs-card-bg img, .cs-card-bg svg {
    width: 100%; height: 100%;
    object-fit: cover;
  }

  .cs-overlay {
    position: absolute;
    top: 0; left: 0; width: 100%; height: 100%;
    background: linear-gradient(to bottom, rgba(0,0,0,0) 20%, rgba(0,0,0,0.85) 100%);
    z-index: 2;
  }
  .cs-card-info {
    position: relative;
    z-index: 3;
    padding: 20px 24px ;
    color: #fff;
    width: 100%;
    text-align: left;
    background: linear-gradient(180deg,transparent -.86%,rgba(0,0,0,.45) 32.38%,rgba(0,0,0,.67) 98.99%,rgba(0,0,0,.67) 124.87%);
  }
  .cs-title {
    font-size:var(--font-size-18);
    font-weight: 500;
    color: #fff;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .cs-preview {
    font-size: var(--font-size-14);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    margin-bottom: 16px;
  }
  .cs-card-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .cs-btn-primary {
    background: transparent;
    border: none;
    color: #fff;
    padding: 0;
    font-size: var(--font-size-14);
    font-weight: 500;
    cursor: pointer;
    text-transform: none;
  }
  .cs-footer-arrow {
    display: flex;
    align-items: center;
  }
  

  /* Modal Styles */
  .cs-modal {
    position: fixed;
    top: 0; left: 0; width: 100%; height: 100%;
    z-index: 999999;
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: none;
  }
  .cs-modal.is-open {
    pointer-events: auto;
  }
  .cs-modal-backdrop {
    position: absolute;
    top: 0; left: 0; width: 100%; height: 100%;
    background: rgba(0,0,0,0.7);
    backdrop-filter: blur(5px);
    opacity: 0;
    transition: opacity 0.3s ease;
    cursor: pointer;
  }
  .cs-modal.is-open .cs-modal-backdrop {
    opacity: 1;
  }
  .cs-modal-dialog {
    background: #fff;
    color: #333;
    width: 95%;
    max-width:1280px;
    height:100%;
    max-height:840px;
    border-radius: 8px;
    position: relative;
    box-shadow: 0 25px 50px -12px rgba(0,0,0,0.25);
    transform: translateY(20px);
    opacity: 0;
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.4s ease;
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }
  .cs-modal.is-open .cs-modal-dialog {
    transform: translateY(0);
    opacity: 1;
  }
  .cs-modal-header-nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 19px 25px;
    flex-shrink: 0;
  }
  .cs-modal-close-new, .cs-modal-next-top {
    background: none;
    border: none;
    cursor: pointer;
    color: #666666;
    font-size: var(--font-size-14);
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .cs-modal-header-title {
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
    font-size: var(--font-size-14);
    font-weight: 500;
    text-transform: uppercase;
    color: var(--color-black);
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.3s ease;
  }
  .cs-modal-header-title.is-visible {
    opacity: 1;
  }
  
  .cs-modal-body {
    flex: 1;
    overflow-y: auto;
    padding: 0;
    transition: transform 0.3s cubic-bezier(0.25, 0.46, 0.45, 0.94), opacity 0.2s ease;
  }
  .cs-modal-body.is-switching {
    opacity: 0.1;
    transform: translateX(-15px);
  }
  .cs-modal-body.is-incoming {
    transition: none !important;
    opacity: 0.1;
    transform: translateX(15px);
  }
  .cs-modal-body::-webkit-scrollbar { display: none; }
  .cs-modal-body {
    -ms-overflow-style: none; /* IE and Edge */
    scrollbar-width: none; /* Firefox */
  }

  /* Body Content Styling */
  .cs-popup-nav-header { text-align: center;}
  .cs-popup-static-meet { font-size: var(--font-size-14);color:var(--color-black) }
  .cs-popup-main-title { font-size: var(--font-size-26); font-weight: 600; text-transform: uppercase;color:var(--color-black);margin:5px 0px 48px 0px; }
  .cs-popup-subtitle { font-size: var(--font-size-14); color: #666; margin: 0 0 48px 0; letter-spacing: 0.05em; font-weight: 400; }
  
  .cs-popup-image-full { width: 100%; max-width: 820px;margin: 0px auto;}
  .cs-img-popup { width: 100%; border-radius: 8px; display: block; height: 400px;object-fit:cover; }
  
  .cs-popup-content-section {
    padding: 24px 0px;
    text-align: center;
    max-width: 700px;
    margin: 0 auto;
  }
  .cs-popup-product-section{
       text-align: center;
    max-width: 700px;
    margin: 0 auto;
  }
  .cs-popup-static-heading { font-size:  var(--font-size-18); font-weight: 500; display: block; text-transform: uppercase; margin: 18px 0px; }
  .cs-popup-story-prose { font-size: var(--font-size-12); line-height: 1.6;color:var(--color-black);margin-bottom:80px;}
.cs-popup-story-badge-prose{
  font-size: var(--font-size-12);
 color:var(--color-black); 
 line-height: 24px;
}
  .cs-popup-review-section-new {
    background: #ffecd6;
    text-align: center;
    width: 100%;
    margin-top: 80px;
    padding-bottom: 48px;
    padding-top: 1px;
  }
  .cs-popup-review-inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 40px;
  }
  .cs-popup-review-image {
    max-width: 660px;
    margin:-140px auto 24px auto;
    position: relative;
    z-index: 10;
  }
  .cs-popup-review-image img {
    box-shadow: 0 25px 50px -12px rgba(0,0,0,0.15);
    border-radius: 12px;
    display: block;
    width: 100%;
  }
  .cs-popup-review-badge-container {
    margin-bottom: 16px;
  }
  .cs-popup-review-badge {
    font-size: var(--font-size-18);
    letter-spacing: 0.1em;
    font-weight: 500;
    text-transform: uppercase;
    display: inline-block;
    color:var(--color-black);
  }
  
  .cs-popup-product-card {
    display: flex;
    align-items: center;
    text-align: left;
    background: #fff;
    border: 1px solid #eee;
    padding: 15px;
    border-radius: 8px;
    text-decoration: none;
    color: inherit;
    gap: 20px;
    margin-top: 15px;
  }
  .cs-popup-prod-img { flex: 0 0 100px; }
  .cs-popup-prod-img img { width: 100%; height: auto; border-radius: 4px; }
  .cs-popup-prod-details { display: flex; flex-direction: column; gap: 4px; }
  .cs-popup-prod-title { font-weight: 600; font-size: 1rem; }
  .cs-popup-prod-price { font-size: 0.9rem; opacity: 0.7; }
  .cs-popup-prod-link { font-size: 0.75rem; letter-spacing: 0.1em; font-weight: 600; margin-top: 4px; }
  
  @media (max-width: 767px) {
    .cs-modal-header-nav {
      padding: 19px 0px;
    }
    .cs-modal-next-top{
      gap:0px;
    }
    .cs-modal-dialog { padding: 30px 20px; }
    .cs-popup-title { font-size: 2rem; }
    .cs-gallery-img { flex: 0 0 calc(80% - 10px); }
    .cs-modal-header-title{
      font-size: var(--font-size-12);
    }
  }

  .cs-modal-next-top.is-shortened .cs-next-label-full {
    display: none;
  }

  body.cs-modal-open {
    overflow: hidden !important;
  }
{% endstyle %}

<script>
if (!customElements.get('couple-stories-slider')) {
  customElements.define('couple-stories-slider', class extends HTMLElement {
    constructor() {
      super();
      this.modal = this.querySelector('.cs-modal');
      this.modalBody = this.querySelector('.cs-modal-body');
      this.closeBtn = this.querySelector('.cs-modal-close-new');
      this.nextTopBtn = this.querySelector('.cs-modal-next-top');
      this.modalHeaderTitle = this.querySelector('.cs-modal-header-title');
      this.backdrop = this.querySelector('.cs-modal-backdrop');
      this.slider = this.querySelector('.cs-slider');
      this.sliderPrevBtn = this.querySelector('.cs-arrow-prev');
      this.sliderNextBtn = this.querySelector('.cs-arrow-next');
      this.progressBar = this.querySelector('.cs-progress-bar');
      
      this.slides = this.querySelectorAll('.cs-slide');
      this.totalCards = this.slides.length;
      this.currentIndex = 0;
      this.autoplayInterval = null;

      if (this.totalCards > 0) {
        this.init();
      }
    }

    init() {
      if (this.modalBody) {
        this.modalBody.addEventListener('scroll', () => {
          if (this.modalHeaderTitle) {
            if (this.modalBody.scrollTop > 50) {
              this.modalHeaderTitle.classList.add('is-visible');
              if (this.nextTopBtn) this.nextTopBtn.classList.add('is-shortened');
            } else {
              this.modalHeaderTitle.classList.remove('is-visible');
              if (this.nextTopBtn) this.nextTopBtn.classList.remove('is-shortened');
            }
          }
        }, { passive: true });
      }

      // Dragging logic
      let isDown = false;
      let startX;
      let scrollLeft;

      this.slider.addEventListener('mousedown', (e) => {
        isDown = true;
        this.slider.classList.add('is-dragging');
        startX = e.pageX - this.slider.offsetLeft;
        scrollLeft = this.slider.scrollLeft;
      });
      this.slider.addEventListener('mouseleave', () => {
        isDown = false;
        this.slider.classList.remove('is-dragging');
      });
      this.slider.addEventListener('mouseup', () => {
        isDown = false;
        this.slider.classList.remove('is-dragging');
      });
      this.slider.addEventListener('mousemove', (e) => {
        if(!isDown) return;
        e.preventDefault();
        const x = e.pageX - this.slider.offsetLeft;
        const walk = (x - startX) * 2; // scroll-fast
        this.slider.scrollLeft = scrollLeft - walk;
      });

      // Main slider arrows
      if(this.sliderPrevBtn) {
        this.sliderPrevBtn.addEventListener('click', () => {
          const slideWidth = this.slides[0].offsetWidth;
          this.slider.scrollBy({ left: -(slideWidth + 20), behavior: 'smooth' });
        });
      }
      if(this.sliderNextBtn) {
        this.sliderNextBtn.addEventListener('click', () => {
          const slideWidth = this.slides[0].offsetWidth;
          this.slider.scrollBy({ left: slideWidth + 20, behavior: 'smooth' });
        });
      }

      // Progress bar logic
      if(this.slider && this.progressBar) {
        this.updateProgressBar();
        this.slider.addEventListener('scroll', () => {
           requestAnimationFrame(() => this.updateProgressBar());
        }, {passive: true});
      }

      // Modal connections
      this.querySelectorAll('.cs-read-more, .cs-card').forEach(btn => {
        btn.addEventListener('click', (e) => {
          e.preventDefault();
          const slide = e.target.closest('.cs-slide');
          if (slide) {
             const index = parseInt(slide.getAttribute('data-index'));
             this.openModal(index);
          }
        });
      });

      if (this.closeBtn) this.closeBtn.addEventListener('click', () => this.closeModal());
      
      // Close modal when clicking outside the dialog
      this.modal.addEventListener('click', (event) => {
        if (event.target === this.modal || event.target === this.backdrop) {
          this.closeModal();
        }
      });

      if (this.nextTopBtn) this.nextTopBtn.addEventListener('click', () => this.openModal(this.currentIndex + 1));
      
      this.startAutoplay();
      if(this.slider) {
        this.slider.addEventListener('mouseenter', () => this.stopAutoplay());
        this.slider.addEventListener('mouseleave', () => this.startAutoplay());
        this.slider.addEventListener('touchstart', () => this.stopAutoplay(), {passive: true});
      }

      // Close on Escape key
      window.addEventListener('keydown', (event) => {
        if (event.key === 'Escape' && this.modal.classList.contains('is-open')) {
          this.closeModal();
        }
      });
    }
    
    updateProgressBar() {
      const scrollLeft = this.slider.scrollLeft;
      const scrollWidth = this.slider.scrollWidth;
      const clientWidth = this.slider.clientWidth;
      
      let percentage = (scrollLeft / (scrollWidth - clientWidth)) * 100;
      if(isNaN(percentage) || percentage < 0) percentage = 0;
      if(percentage > 100) percentage = 100;
      
      this.progressBar.style.width = percentage + '%';
    }

    openModal(index) {
      if (index < 0 || index >= this.totalCards) return;
      this.currentIndex = index;
      const card = this.querySelector(`.cs-slide[data-index="${this.currentIndex}"]`);
      if (!card) return;

      // Sync slider position
      this.syncSlider(index);

      const template = card.querySelector('.story-popup-data');
      if (!template) return;
      
      if (!this.modal.getAttribute('aria-hidden') || this.modal.getAttribute('aria-hidden') === 'false') {
          this.modalBody.classList.add('is-switching');
          setTimeout(() => {
              this.modalBody.innerHTML = template.innerHTML;
              this.modalBody.classList.remove('is-switching');
              this.modalBody.classList.add('is-incoming');

              // Sync slide layout
              this.updateNav();
              if (this.modalHeaderTitle) {
                  const titleEl = card.querySelector('.cs-title');
                  this.modalHeaderTitle.textContent = titleEl ? titleEl.textContent : '';
                  this.modalHeaderTitle.classList.remove('is-visible');
                  if (this.nextTopBtn) this.nextTopBtn.classList.remove('is-shortened');
              }
              
              this.modalBody.scrollTop = 0;

              // Force reflow and start incoming animation
              requestAnimationFrame(() => {
                requestAnimationFrame(() => {
                  this.modalBody.classList.remove('is-incoming');
                });
              });
          }, 150);
      } else {
          this.modalBody.innerHTML = template.innerHTML;
          this.modal.setAttribute('aria-hidden', 'false');
          document.body.classList.add('cs-modal-open');
          this.modal.classList.add('is-open');
          this.updateNav();
          if (this.modalHeaderTitle) {
              const titleEl = card.querySelector('.cs-title');
              this.modalHeaderTitle.textContent = titleEl ? titleEl.textContent : '';
              this.modalHeaderTitle.classList.remove('is-visible');
              if (this.nextTopBtn) this.nextTopBtn.classList.remove('is-shortened');
          }
          this.modalBody.scrollTop = 0;
      }
    }

    syncSlider(index) {
      const targetSlide = this.querySelector(`.cs-slide[data-index="${index}"]`);
      if (targetSlide && this.slider) {
        const sliderRect = this.slider.getBoundingClientRect();
        const slideRect = targetSlide.getBoundingClientRect();
        const offset = targetSlide.offsetLeft - (this.slider.clientWidth / 2) + (targetSlide.clientWidth / 2);
        
        this.slider.scrollTo({
          left: offset,
          behavior: 'smooth'
        });
      }
    }

    closeModal() {
      if (this.modal) {
        this.modal.classList.remove('is-open');
        this.modal.setAttribute('aria-hidden', 'true');
        document.body.classList.remove('cs-modal-open');
      }
    }

    updateNav() {
      if (this.nextTopBtn) {
        this.nextTopBtn.style.visibility = this.currentIndex < this.totalCards - 1 ? 'visible' : 'hidden';
      }
    }

    startAutoplay() {
      const autoplayEnabled = this.hasAttribute('data-autoplay') && this.getAttribute('data-autoplay') === 'true';
      if (!autoplayEnabled || !this.slider || this.totalCards <= 1) return;

      this.autoplayInterval = setInterval(() => {
        if(this.modal && this.modal.classList.contains('is-open')) return;
        
        const scrollWidth = this.slider.scrollWidth;
        const clientWidth = this.slider.clientWidth;
        
        if(this.slider.scrollLeft + clientWidth >= scrollWidth - 10) {
          this.slider.scrollTo({ left: 0, behavior: 'smooth' });
        } else {
          const slide = this.querySelector('.cs-slide');
          if (slide) {
            this.slider.scrollBy({ left: slide.offsetWidth + 20, behavior: 'smooth' });
          }
        }
      }, 4000);
    }

    stopAutoplay() {
      if (this.autoplayInterval) {
        clearInterval(this.autoplayInterval);
        this.autoplayInterval = null;
      }
    }
  });
}
</script>

{% schema %}
{
