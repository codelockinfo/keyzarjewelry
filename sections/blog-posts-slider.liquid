{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top_mobile }}px;
    padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
    {%- unless section.settings.color_scheme != blank -%}
      background-color: {{ section.settings.bg_color }};
      color: {{ section.settings.text_color }};
    {%- endunless -%}
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top_desktop }}px;
      padding-bottom: {{ section.settings.padding_bottom_desktop }}px;
    }
  }

  .blog-slider-container {
    max-width: var(--page-width);
    margin: 0 auto;
    padding: 0 20px;
    position: relative;
  }

  .blog-slider-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 80px;
  }

  .blog-slider-header h2 {
    margin: 0;
    font-size: clamp(var(--font-size-24), 4vw, var(--font-size-36));
    letter-spacing: 0.05em;
    font-weight: 400;
  }

  .blog-slider-nav {
    display: flex;
    gap: 15px;
    align-items: center;
  }

  .blog-slider-prev,
  .blog-slider-next {
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    transition: all 0.3s ease;
    border-radius: 50%;
  }

  .blog-slider-prev:hover,
  .blog-slider-next:hover {
    background: rgba(0,0,0,0.05);
  }

  .blog-slider-prev.swiper-button-disabled,
  .blog-slider-next.swiper-button-disabled {
    opacity: 0.2;
    cursor: auto;
  }

  .blog-slider-nav svg {
    width: 20px;
    height: 20px;
    stroke: currentColor;
    stroke-width: 1.2;
  }

  @media screen and (max-width: 1024px) {
    .blog-slider-header {
        margin-bottom:48px;
    }
  }
  @media screen and (max-width: 749px) {
    {% if section.settings.hide_nav_mobile %}
    .blog-slider-nav {
      display: none;
    }
    {% endif %}
    .blog-slider-header {
      display:block;
      text-align:center;
        margin-bottom:32px;
    }
  }

  /* Swiper Cards */
  .blog-post-card {
    position: relative;
    border-radius: {{ section.settings.block_border_radius }}px;
    overflow: hidden;
    height: 100%;
    aspect-ratio: 1 / 1.1;
    display: block;
    text-decoration: none;
    color: #fff;
  }

  .blog-post-card img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 1.2s cubic-bezier(0.165, 0.84, 0.44, 1);
  }

  .blog-post-card:hover img {
    transform: scale(1.08);
  }

  .blog-post-overlay {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 2.5rem;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    height: 50%;
    transition: height 0.4s ease;
    background: linear-gradient(to top, rgba(0,0,0,0.85) 0%, rgba(0,0,0,0.3) 60%, transparent 100%);
    color: #ffffff;
  }

  .blog-post-title {
    font-size: var(--font-size-18);
    font-weight: 500;
    margin: 0 0 1.5rem 0;
    line-height: 1.3;
    color:white;
  }

  .blog-post-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    transition: opacity 0.3s ease;
  }

  .blog-post-readmore {
    font-size: var(--font-size-14);
    text-transform: uppercase;
    letter-spacing: 0.05rem;
    opacity: 0.8;
  }

  .blog-post-arrow {
    width: 32px;
    height: 12px;
    opacity: 0.8;
  }

  /* Swiper Pagination Progress override */
  .blog-slider-pagination-wrap {
      margin-top: 40px;
      padding: 0;
  }
  
  .blogSlider-{{ section.id }} .swiper-pagination-progressbar {
      background: rgba(0,0,0,0.08) !important;
      position: relative !important;
      height: 2px !important;
      border-radius: 2px;
  }
  .blogSlider-{{ section.id }} .swiper-pagination-progressbar-fill {
      background: #000 !important;
      border-radius: 2px;
  }

  /* Bottom Button */
  .blog-slider-footer {
    margin-top: 50px;
    display: flex;
    justify-content: center;
  }

  .blog-slider-visit-btn {
    display: inline-block;
    background: #000;
    color: #fff !important;
    padding: 14px 45px;
    border-radius: 100px;
    text-decoration: none;
    font-weight: 500;
    font-size: var(--font-size-16);
    transition: all 0.3s ease;
    border: 1px solid #000;
    text-transform: capitalize;
  }

  .blog-slider-visit-btn:hover {
    background: transparent;
    color: #000 !important;
    transform: scale(1.05);
  }
{%- endstyle -%}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" />
<script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>

<div class="color-{{ section.settings.color_scheme }} gradient section-{{ section.id }}-padding" id="section-{{ section.id }}">
  <div class="blog-slider-container">
    
    <div class="blog-slider-header">
      <h2>{{ section.settings.heading }}</h2>
      <div class="blog-slider-nav">
        <div class="blog-slider-prev">
         <svg class="w-8 h-8" aria-hidden="true" focusable="false"><svg viewBox="0 0 26 28" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M18.1212 4.08742L7.87879 14.3298L18.1212 24.5723" stroke="currentColor" stroke-width="2.5"></path></svg></svg>
        </div>
        <div class="blog-slider-next">
        <svg class="w-8 h-8" aria-hidden="true" focusable="false"><svg viewBox="0 0 26 28" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M7.87891 24.5722L18.1213 14.3298L7.87891 4.0874" stroke="currentColor" stroke-width="2.5"></path></svg></svg>
        </div>
      </div>
    </div>

    <div class="swiper blogSlider-{{ section.id }}">
      <div class="swiper-wrapper">
        {%- for block in section.blocks -%}
          {%- liquid
            assign article = block.settings.article
            
            if article != blank
               assign image = article.image
               assign title = article.title
               assign link = article.url
            else
               assign title = "Select an Article"
               assign link = "#"
            endif
          -%}
          <div class="swiper-slide" {{ block.shopify_attributes }}>
            <a href="{{ link }}" class="blog-post-card">
              {%- if image != blank -%}
                <img 
                  src="{{ image | image_url: width: 800 }}"
                  alt="{{ title | escape }}"
                  loading="lazy"
                  width="{{ image.width }}"
                  height="{{ image.height }}"
                >
              {%- else -%}
                {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
              {%- endif -%}
              
              <div class="blog-post-overlay">
                <div class="blog-post-title">{{ title }}</div>
                <div class="blog-post-footer">
                  <span class="blog-post-readmore">Read More</span>
                  <svg class="blog-post-arrow w-8 h-3" viewBox="0 0 34 14"><svg width="34" height="14" viewBox="0 0 34 14" fill="none" xmlns="http://www.w3.org/2000/svg"><rect y="6.5" width="32" height="1" rx="0.5" fill="currentColor"></rect><path d="M26.3555 12.7271L32.1226 7.00005L26.3555 1.27295" stroke="currentColor" stroke-linecap="round"></path></svg></svg>
                </div>
              </div>
            </a>
          </div>
        {%- endfor -%}
      </div>
      
      <div class="blog-slider-pagination-wrap">
          <div class="swiper-pagination blog-slider-pagination-{{ section.id }}"></div>
      </div>
    </div>

    {%- if section.settings.button_label != blank -%}
      <div class="blog-slider-footer">
        <a href="{{ section.settings.button_link }}" class="blog-slider-visit-btn">
          {{ section.settings.button_label }}
        </a>
      </div>
    {%- endif -%}
  </div>
</div>

<script>
  function initBlogSlider_{{ section.id | replace: '-', '_' }}() {
      new Swiper('.blogSlider-{{ section.id }}', {
        slidesPerView: {{ section.settings.slides_mobile }},
        spaceBetween: 20,
        navigation: {
          nextEl: '.blog-slider-next',
          prevEl: '.blog-slider-prev',
        },
        pagination: {
          el: '.blog-slider-pagination-{{ section.id }}',
          type: 'progressbar',
        },
        breakpoints: {
          750: {
            slidesPerView: {{ section.settings.slides_tablet }},
            spaceBetween: 24,
          },
          1024: {
            slidesPerView: {{ section.settings.slides_tablet }},
            spaceBetween: 40,
          },
          1200: {
            slidesPerView: {{ section.settings.slides_desktop }},
            spaceBetween: 48,
          }
        }
      });
  }

  document.addEventListener('DOMContentLoaded', initBlogSlider_{{ section.id | replace: '-', '_' }});

  // Re-init in shopify editor
  document.addEventListener('shopify:section:load', function(e) {
    if (e.detail.sectionId === '{{ section.id }}') {
       initBlogSlider_{{ section.id | replace: '-', '_' }}();
    }
  });
</script>

{% schema %}
{
  "name": "Custom Blog Slider",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section Heading",
      "default": "THE JEWELRY BLOG"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color Scheme",
      "default": "scheme-1"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color (Fallback)",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color (Fallback)",
      "default": "#000000"
    },
    {
       "type": "range",
       "id": "block_border_radius",
       "min": 0,
       "max": 50,
       "step": 1,
       "unit": "px",
       "label": "Block Border Radius",
       "default": 12
    },
    {
      "type": "header",
      "content": "Slider Settings"
    },
    {
      "type": "range",
      "id": "slides_desktop",
      "min": 1,
      "max": 5,
      "step": 1,
      "label": "Slides per view (Desktop)",
      "default": 3
    },
    {
      "type": "range",
      "id": "slides_tablet",
      "min": 1,
      "max": 4,
      "step": 1,
      "label": "Slides per view (Tablet)",
      "default": 2
    },
    {
      "type": "range",
      "id": "slides_mobile",
      "min": 1,
      "max": 3,
      "step": 0.1,
      "label": "Slides per view (Mobile)",
      "default": 1.2
    },
    {
      "type": "checkbox",
      "id": "hide_nav_mobile",
      "label": "Hide Next/Prev Buttons on Mobile",
      "default": true
    },
    {
      "type": "header",
      "content": "Footer Button"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "Visit the Blog"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    },
    {
      "type": "header",
      "content": "Section Padding"
    },
    {
      "type": "range",
      "id": "padding_top_desktop",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top Desktop",
      "default": 64
    },
    {
      "type": "range",
      "id": "padding_bottom_desktop",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom Desktop",
      "default": 64
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top Mobile",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom Mobile",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "post",
      "name": "Post",
      "settings": [
        {
          "type": "article",
          "id": "article",
          "label": "Select Article",
          "info": "Automatically pulls image, title, and link from the selected blog post."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Custom Blog Slider",
      "blocks": [
        { "type": "post" },
        { "type": "post" },
        { "type": "post" }
      ]
    }
  ]
}
{% endschema %}
