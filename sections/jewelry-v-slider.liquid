{%- style -%}
  @import url('https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;500;600&family=Playfair+Display:ital,wght@0,400..900;1,400..900&display=swap');

  .jewelry-v-slider-{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    background-color: {{ section.settings.bg_color }};
    overflow: hidden;
    width: 100%;
    position: relative;
    font-family: 'Montserrat', sans-serif;
  }

  .jewelry-v-slider-{{ section.id }} .jewelry-v-slider__header {
    text-align: center;
    margin-bottom: 20px;
  }

  .jewelry-v-slider-{{ section.id }} .jewelry-v-slider__title {
    font-size: var(--font-size-40);
    font-weight: 700;
    letter-spacing: 4px;
    margin: 0;
    color: #1a1a1a;
  }

  .jewelry-v-slider-{{ section.id }} .jewelry-v-slider__subtitle {
    font-size: 16px;
    color: #120d0d;
    max-width: 600px;
    margin: 10px auto 0;
    line-height: 1.6;
    padding: 0 15px;
    font-weight: 400;
  }

  /* Compact Swiper Container to remove White Space Gap */
  .jewelry-v-slider-{{ section.id }} .swiper-jewelry-v {
    padding: 100px 0 30px; 
    overflow: visible !important;
  }

  .jewelry-v-slider-{{ section.id }} .swiper-slide {
    display: flex;
    justify-content: center;
    align-items: center;
    transition: opacity 0.4s ease;
    width: 250px; /* Base width */
  }

  @media screen and (min-width: 768px) {
    .jewelry-v-slider-{{ section.id }} .swiper-slide {
      width: 20% !important; /* Force 5 slides view */
    }
  }

  .jewelry-v-slider-{{ section.id }} .jewelry-v-slider__img-container {
    width: 100%;
    max-width: 262px;
    position: relative;
    transition: transform 0.6s cubic-bezier(0.2, 0.8, 0.4, 1);
    transform-origin: center center;
  }

  .jewelry-v-slider-{{ section.id }} .jewelry-v-slider__img-container img {
    width: 100%;
    height: auto;
    display: block;
    object-fit: contain;
    user-select: none;
    -webkit-user-drag: none;
  }

  /* Info at the bottom, No overlapping */
  .jewelry-v-slider-{{ section.id }} .jewelry-v-slider__info {
    text-align: center;
    margin-top: 10px;
    padding-top: 20px;
    position: relative;
    z-index: 80;
  }
  
  .jewelry-v-slider-{{ section.id }} .jewelry-v-slider__info .jewelry-v-slider__active-title,
  .jewelry-v-slider-{{ section.id }} .jewelry-v-slider__info .jewelry-v-slider__active-desc {
    transition: opacity 0.3s ease;
  }

  .jewelry-v-slider-{{ section.id }} .jewelry-v-slider__info.is-changing .jewelry-v-slider__active-title,
  .jewelry-v-slider-{{ section.id }} .jewelry-v-slider__info.is-changing .jewelry-v-slider__active-desc {
    opacity: 0;
  }

  .jewelry-v-slider-{{ section.id }} .jewelry-v-slider__controls {
    display: flex;
    justify-content: center;
    align-items: center;
    margin-bottom: 5px;
    position: relative;
    width: 100%;
    max-width: 600px;
    margin: 0 auto;
    min-height: 55px;
    padding: 0 20px;
  }

  .jewelry-v-slider-{{ section.id }} .jewelry-v-slider__btn {
    width: 44px;
    height: 44px;
    border: 1px solid #e0e0e0;
    border-radius: 50%;
    background: #fff;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s ease;
    color: #1a1a1a;
    padding: 0;
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 10;
  }

  .jewelry-v-slider-{{ section.id }} .jewelry-v-nav-prev-{{ section.id }} {
    left: 10px;
  }

  .jewelry-v-slider-{{ section.id }} .jewelry-v-nav-next-{{ section.id }} {
    right: 10px;
  }

  .jewelry-v-slider-{{ section.id }} .jewelry-v-slider__btn:hover {
    background: #1a1a1a;
    color: #fff;
    border-color: #1a1a1a;
  }

  .jewelry-v-slider-{{ section.id }} .jewelry-v-slider__btn svg {
    width: 20px;
    height: 20px;
  }

  .jewelry-v-slider-{{ section.id }} .jewelry-v-slider__active-title {
    font-family: 'Playfair Display', serif;
    font-size: clamp(22px, 3vw, 32px);
    margin: 0;
    font-weight: 400;
    line-height: 1.2;
    min-height: 1.2em;
    padding: 0 60px; /* Space for absolute buttons */
    text-align: center;
  }

  .jewelry-v-slider-{{ section.id }} .jewelry-v-slider__active-desc {
    font-size: 14px;
    color: #777;
    margin-top: 5px;
    letter-spacing: 0.3px;
    min-height: 1.4em;
    padding: 0 20px;
  }

  @media screen and (max-width: 767px) {
    .jewelry-v-slider-{{ section.id }} .swiper-jewelry-v {
      padding: 80px 0 60px;
    }
    .jewelry-v-slider-{{ section.id }} .jewelry-v-slider__controls {
      max-width: 100%;
      min-height: 50px;
    }
    .jewelry-v-slider-{{ section.id }} .jewelry-v-slider__active-title {
      font-size: 24px;
      padding: 0 55px;
    }
      .jewelry-v-slider-{{ section.id }} .jewelry-v-slider__title {
 font-size: 32px;
    }
  }
{%- endstyle -%}

<div class="jewelry-v-slider-{{ section.id }}" id="V-Slider-{{ section.id }}">
  <div class="jewelry-v-slider__header">
    <h2 class="jewelry-v-slider__title">{{ section.settings.title }}</h2>
    <div class="jewelry-v-slider__subtitle">{{ section.settings.description }}</div>
  </div>

  <div class="page-width" style="max-width: 1800px;">
    <div class="swiper swiper-jewelry-v">
      <div class="swiper-wrapper">
        {%- comment -%} Triple slides for loop stability with 5-slide-view {%- endcomment -%}
        {%- for i in (1..3) -%}
          {%- for block in section.blocks -%}
            <div class="swiper-slide" {{ block.shopify_attributes }} 
                 data-title="{{ block.settings.title | escape }}" 
                 data-desc="{{ block.settings.description | escape }}">
              <div class="jewelry-v-slider__img-container">
                {%- if block.settings.image != blank -%}
                  <img src="{{ block.settings.image | image_url: width: 500 }}" alt="{{ block.settings.image.alt }}" loading="lazy">
                {%- else -%}
                  {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
                {%- endif -%}
              </div>
            </div>
          {%- endfor -%}
        {%- endfor -%}
      </div>
    </div>

    <div class="jewelry-v-slider__info" id="jewelry-v-info-{{ section.id }}">
      <div class="jewelry-v-slider__controls">
        <button class="jewelry-v-slider__btn jewelry-v-nav-prev-{{ section.id }}">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polyline points="15 18 9 12 15 6"></polyline></svg>
        </button>
        <h3 class="jewelry-v-slider__active-title" id="jewelry-v-title-{{ section.id }}"></h3>
        <button class="jewelry-v-slider__btn jewelry-v-nav-next-{{ section.id }}">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polyline points="9 18 15 12 9 6"></polyline></svg>
        </button>
      </div>
      <div class="jewelry-v-slider__active-desc" id="jewelry-v-desc-{{ section.id }}"></div>
    </div>
  </div>
</div>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" />
<script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>

<script>
(function() {
  function init() {
    const sectionId = '{{ section.id }}';
    const container = document.querySelector(`#V-Slider-${sectionId}`);
    if (!container || !window.Swiper) return;

    const titleEl = container.querySelector('#jewelry-v-title-{{ section.id }}');
    const descEl = container.querySelector('#jewelry-v-desc-{{ section.id }}');
    const infoWrap = container.querySelector('#jewelry-v-info-{{ section.id }}');

    const swiper = new Swiper(`#V-Slider-${sectionId} .swiper-jewelry-v`, {
      slidesPerView: 1.5,
      centeredSlides: true,
      loop: true,
      speed: 800,
      allowTouchMove: false,
      watchSlidesProgress: true,
      updateOnImagesReady: true,
      navigation: {
        nextEl: `.jewelry-v-nav-next-${sectionId}`,
        prevEl: `.jewelry-v-nav-prev-${sectionId}`,
      },
      breakpoints: {
        768: {
          slidesPerView: 5
        }
      },
      on: {
        init: function() {
          this.update();
          updateText(this);
          applyV(this);
          setTimeout(() => {
            this.update();
            applyV(this);
          }, 300);
        },
        slideChange: function() {
          updateText(this);
        },
        setTranslate: function() {
          applyV(this);
        }
      }
    });

    function updateText(s) {
      const active = s.slides[s.activeIndex];
      if (active && titleEl && descEl) {
        const title = active.getAttribute('data-title');
        const desc = active.getAttribute('data-desc');
        
        infoWrap.classList.add('is-changing');
        
        setTimeout(() => {
          titleEl.textContent = title;
          descEl.textContent = desc;
          infoWrap.classList.remove('is-changing');
        }, 300);
      }
    }

    function applyV(s) {
      const isMobile = window.innerWidth < 768;
      const slides = s.slides;
      
      for (let i = 0; i < slides.length; i++) {
        const slide = slides[i];
        const progress = slide.progress;
        const absProgress = Math.abs(progress);
        const imgWrap = slide.querySelector('.jewelry-v-slider__img-container');

        if (!imgWrap) continue;

        // V-Shape: Center is vertex (0), sides rise UP (Negative translate)
        // User requested exactly -54px for the 1st neighbor (progress 1)
        const slope = isMobile ? 40 : 54;
        const translateY = - (absProgress * slope);
        
        // Gap Hack: Pull smaller rings slightly closer to the center
        // Balancing to ensure all 5 slides stay visible without overlapping.
        const xFactor = isMobile ? 0 : 35; 
        const xOffset = - (progress * xFactor);
        
        // Custom Scale: Center (1.45), Neighbor (1.1), Edge (0.75)
        const scaleBase = isMobile ? 1.3 : 1.45;
        const scaleDrop = 0.35; 
        const scale = scaleBase - (Math.min(absProgress, 3) * scaleDrop);

        imgWrap.style.transform = `translate3d(${xOffset}px, ${translateY}px, 0) scale(${Math.max(0.6, scale)})`;
        slide.style.zIndex = Math.round(100 - (absProgress * 20));
        
        // Visibility for exactly 5 slides total (Center + 2 on each side)
        if (absProgress > 2.2) {
          slide.style.opacity = 0;
          slide.style.visibility = 'hidden';
          slide.style.pointerEvents = 'none';
        } else {
          slide.style.opacity = 1; // Full opacity for all 5 visible slides
          slide.style.visibility = 'visible';
          slide.style.pointerEvents = 'auto';
        }
      }
    }

    window.addEventListener('resize', () => {
      swiper.update();
      applyV(swiper);
    });
  }

  document.addEventListener('DOMContentLoaded', init);
  if (window.Shopify && window.Shopify.designMode) {
    document.addEventListener('shopify:section:load', init);
  }
})();
</script>

{% schema %}
{
  "name": "Jewelry V-Slider",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "DISCOVER STYLES"
    },
    {
      "type": "text",
      "id": "description",
      "label": "Description",
      "default": "Discover diverse engagement ring styles, each embodying a distinct symbol of love and devotion"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top Padding",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom Padding",
      "default": 60
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Hidden Halo"
        },
        {
          "type": "text",
          "id": "description",
          "label": "Description",
          "default": "Intriguing brilliance from a concealed halo."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Jewelry V-Slider",
      "blocks": [
        { "type": "slide" },
        { "type": "slide" },
        { "type": "slide" }
      ]
    }
  ]
}
{% endschema %}
