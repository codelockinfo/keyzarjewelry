{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .collection-slider-{{ section.id }} {
    background-color: {{ section.settings.bg_color | default: '#ffffff' }};
  }

  .collection-slider-{{ section.id }} .section-header {
    text-align: center;
    margin-bottom: 40px;
  }

  .collection-slider-{{ section.id }} .section-title {
    margin: 0;
    font-family: 'Playfair Display', serif;
    font-size: 32px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .cs-card {
    background-color: #f5efe7;
    border-radius: 12px;
    padding: 0;
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
    width: 100%;
    aspect-ratio: 0.85;
    box-sizing: border-box;
    transition: transform 0.3s ease;
    overflow: hidden;
    position: relative;
  }

  .cs-card:hover {
    transform: translateY(-5px);
  }

  .cs-image-wrapper {
    width: 100%;
    height: 100%;
    position: absolute;
    top: 0;
    left: 0;
    z-index: 1;
  }

  .cs-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .cs-content {
    display: flex;
    flex-direction: column;
    margin-top: auto;
    z-index: 2;
    position: relative;
    padding: 20px 20px 25px;
  }

  .cs-title {
    font-size: 22px;
    font-weight: 500;
    margin: 0 0 6px 0;
    font-family: sans-serif;
  }

  .cs-link {
    font-size: 14px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    display: flex;
    align-items: center;
    gap: 6px;
  }
  
  .cs-link svg {
    width: 12px;
    height: 12px;
  }

  .collection-slider-{{ section.id }} .swiper {
    padding-bottom: 20px;
  }
  
  .collection-slider-{{ section.id }} .swiper-wrapper {
    align-items: stretch;
  }
  
  .collection-slider-{{ section.id }} .swiper-slide {
    height: auto;
  }
{%- endstyle -%}

<div class="collection-slider-{{ section.id }} section-{{ section.id }}-padding isolate">
  <div class="page-width">
    {%- unless section.settings.title == blank -%}
      <div class="section-header">
        <h2 class="section-title">{{ section.settings.title }}</h2>
      </div>
    {%- endunless -%}

    <div class="swiper swiper-{{ section.id }}">
      <div class="swiper-wrapper">
        {%- for block in section.blocks -%}
          <div class="swiper-slide" {{ block.shopify_attributes }}>
            {%- liquid
              assign collection = block.settings.collection
              assign title = block.settings.title | default: collection.title
              assign image = block.settings.image | default: collection.featured_image
              assign url = collection.url | default: '#'
              assign card_bg = block.settings.card_bg | default: '#f5efe7'
            -%}
            <a href="{{ url }}" class="cs-card" style="background-color: {{ card_bg }};">
              <div class="cs-image-wrapper">
                {%- if image != blank -%}
                  {{ image | image_url: width: 600 | image_tag: loading: 'lazy', class: 'cs-image' }}
                {%- else -%}
                  {{ 'collection-1' | placeholder_svg_tag: 'cs-image placeholder-svg' }}
                {%- endif -%}
              </div>
              <div class="cs-content">
                <h3 class="cs-title">{{ title | default: 'Collection Title' }}</h3>
                <div class="cs-link">
                  SHOP NOW
                  <svg viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 1L11 7L5 13"></path></svg>
                </div>
              </div>
            </a>
          </div>
        {%- endfor -%}
      </div>
    </div>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    new Swiper('.swiper-{{ section.id }}', {
      slidesPerView: 1.2,
      spaceBetween: 15,
      breakpoints: {
        750: {
          slidesPerView: 2.5,
          spaceBetween: 15
        },
        990: {
          slidesPerView: 4,
          spaceBetween: 15
        }
      }
    });
  });
</script>

{% schema %}
{
  "name": "t:sections.collection-list.name",
  "tag": "section",
  "class": "section section-collection-list",
  "max_blocks": 15,
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "text",
      "id": "title",
      "default": "OUR SELECTIONS",
      "label": "t:sections.collection-list.settings.title.label"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Section Background",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "featured_collection",
      "name": "t:sections.collection-list.blocks.featured_collection.name",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "t:sections.collection-list.blocks.featured_collection.settings.collection.label"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Custom Image",
          "info": "Overrides the default collection image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Custom Title",
          "info": "Overrides the default collection title"
        },
        {
          "type": "color",
          "id": "card_bg",
          "label": "Card Background Color",
          "default": "#f5efe7"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.collection-list.presets.name",
      "blocks": [
        {
          "type": "featured_collection"
        },
        {
          "type": "featured_collection"
        },
        {
          "type": "featured_collection"
        },
        {
          "type": "featured_collection"
        }
      ]
    }
  ]
}
{% endschema %}
